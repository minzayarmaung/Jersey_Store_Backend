package com.mit.storesystem.Service.ServiceImpl.InvoiceServiceImpl;

import java.sql.Connection;
import java.sql.PreparedStatement;
import java.sql.ResultSet;
import java.util.ArrayList;
import java.util.List;

import com.mit.storesystem.Entity.Invoice;
import com.mit.storesystem.Service.Invoice.InvoiceService;
import com.mit.storesystem.Utils.ConnectionDataSource;

public class InvoiceServiceImpl implements InvoiceService {

	// Getting All Invoice Data 
	public List<Invoice> getAllInvoiceData() {
		
		try(Connection connection = ConnectionDataSource.getConnection();
				PreparedStatement statement = connection.prepareStatement(
						"SELECT date, time, invoice_id, branch, cashier_name, center FROM invoice;")) {
				ResultSet result = statement.executeQuery();
				List<Invoice> list = new ArrayList<Invoice>();
				
				while(result.next()) {
					Invoice invoice = new Invoice();
					invoice.setInvoiceId(result.getLong("invoice_id"));
					invoice.setCashierName(result.getString("cashier_name"));
					invoice.setDate(result.getString("date"));
					invoice.setTime(result.getString("time"));
					invoice.setBranch(result.getString("branch"));
					invoice.setCenter(result.getString("center"));
					list.add(invoice);
				}
				return list;
			
		} catch (Exception e) {
		}
		
		return null;
	}

}
