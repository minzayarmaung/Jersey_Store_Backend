
package com.mit.storesystem;

import javax.ws.rs.GET;
import javax.ws.rs.Path;
import javax.ws.rs.Produces;

/** Example resource class hosted at the URI path "/myresource"
 */

@Path("/home")
public class MyResource {
    
    @GET 
    @Path("/text/plain")
    @Produces("text/plain")
    public String getIt() {
        return "Hi there!";
    }
    
}

